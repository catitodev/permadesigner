{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nature Patterns",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "description",
      "guidingQuestions",
      "relatedPrincipleIds"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "name": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": [
              "pt-BR"
            ],
            "properties": {
              "pt-BR": {
                "type": "string"
              },
              "en": {
                "type": "string"
              },
              "es": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "description": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": [
              "pt-BR"
            ],
            "properties": {
              "pt-BR": {
                "type": "string"
              },
              "en": {
                "type": "string"
              },
              "es": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "guidingQuestions": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "required": [
                "pt-BR"
              ],
              "properties": {
                "pt-BR": {
                  "type": "string"
                },
                "en": {
                  "type": "string"
                },
                "es": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "relatedPrincipleIds": {
        "type": "array",
        "items": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        }
      }
    },
    "additionalProperties": false
  }
}