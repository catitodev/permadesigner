# Copie este arquivo para .env.local e preencha com suas próprias credenciais.
# Nunca commite o .env.local — ele já deve estar no .gitignore.

# ─── Supabase (Auth + Postgres + Storage) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Provedores de IA gratuitos (ver docs/free-ai-providers.md) ──────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── Flags de funcionalidade ─────────────────────────────────────────────────
NEXT_PUBLIC_VOICE_ENABLED=true

# ─── URL pública do app (usada em redirects de OAuth) ────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend — free tier 100 emails/dia) ──────────────────────────────
RESEND_API_KEY=
